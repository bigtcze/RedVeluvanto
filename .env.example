# ===========================================
# RedVeluvanto — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- AI (LiteLLM) ---
# Google Gemini API key (get from https://aistudio.google.com/)
GEMINI_API_KEY=

# LiteLLM proxy master key (any secret string, used to auth requests to proxy)
LITELLM_MASTER_KEY=sk-redveluvanto-change-me

# LiteLLM URL (default for Docker Compose, change if running externally)
LITELLM_URL=http://litellm:4000

# AI model for scoring + response generation (must match model_name in litellm config)
AI_FAST_MODEL=gemini-2.5-flash

# --- Reddit OAuth2 ---
# Create a Reddit app at https://www.reddit.com/prefs/apps
# Type: web app, Redirect URI: http://localhost:8090/api/reddit/callback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:8090/api/reddit/callback

# --- Security ---
# Encryption key for Reddit OAuth tokens at rest (any secret string, min 16 chars)
# If not set, falls back to LITELLM_MASTER_KEY
TOKEN_ENCRYPTION_KEY=
